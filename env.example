# Docker image tag to deploy. Update intentionally, not implicitly.
REST_SERVER_IMAGE_TAG=0.14.0

# Compose-level naming for easier operations.
REST_SERVER_CONTAINER_NAME=restic-rest-server

# Listener exposure. Keep 127.0.0.1 when a reverse proxy terminates TLS locally.
REST_SERVER_BIND_ADDRESS=127.0.0.1
REST_SERVER_PUBLISHED_PORT=8000

# Host path that persists repository data and the htpasswd file.
# Default matches the live server's ZFS-backed tank/docker/data layout.
REST_SERVER_DATA_ROOT=/tank/docker/data/restic-rest-server

# Container path for the htpasswd file used by the official image.
REST_SERVER_PASSWORD_FILE=/data/.htpasswd

# Extra flags passed through the official image's OPTIONS environment variable.
# Defaults keep auth enabled, require per-user repository paths, and prevent
# deletion/modification of existing data from clients.
REST_SERVER_OPTIONS="--path /data/repos --append-only --private-repos"
